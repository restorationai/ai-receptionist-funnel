---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <style>
        .schedule-section {
            padding-top: 40px;
            padding-bottom: 60px;
            background-color: #ffffff;
            min-height: 100vh;
        }

        .schedule-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .text-gradient-blue {
            background: -webkit-linear-gradient(0deg, #38bdf8 0%, #0ea5e9 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
        }

        .schedule-divider {
            border: none;
            border-top: 2px solid #000;
            margin: 15px 0;
            width: 100%;
        }

        .mobile-only { display: none; }

        @media (max-width: 768px) {
            .desktop-only { display: none !important; }
            .mobile-only { display: block !important; }
            .schedule-container { padding: 0 10px; }
            
            .schedule-divider {
                margin: 10px 0;
            }
        }
        
        .calendar-placeholder {
            margin-top: 40px;
            padding: 40px 20px;
            background: #f8f9fa;
            border: 2px dashed #ccc;
            border-radius: 12px;
            text-align: center;
        }
    </style>

    <section class="section schedule-section animate-fade-in">
        <div class="schedule-container text-center">
            
            <!-- TOP HEADLINE -->
            <h1 class="fw-black desktop-only" style="text-align: center; font-size: clamp(1.8rem, 3.2vw, 2.5rem); line-height: 1.2; letter-spacing: -0.5px; margin-bottom: 0;">
                See How Our AI <span class="text-gradient-blue">Recovers Thousands</span> in Lost Revenue<br/>
                From Missed Emergency Calls
            </h1>
            
            <h1 class="fw-black mobile-only" style="text-align: center; line-height: 1.15; letter-spacing: -1px; margin-bottom: 0;">
                <span style="font-size: 6.5vw; white-space: nowrap; display: block;">See How Our AI <span class="text-gradient-blue">Recovers</span></span>
                <span style="font-size: 6.5vw; white-space: nowrap; display: block;"><span class="text-gradient-blue">Thousands</span> in Lost Revenue</span>
                <span style="font-size: 6.5vw; white-space: nowrap; display: block;">From Missed Emergency</span>
                <span style="font-size: 6.5vw; white-space: nowrap; display: block;">Calls</span>
            </h1>

            <hr class="schedule-divider" />

            <!-- BOTTOM HEADLINE -->
            <h2 class="fw-black desktop-only" style="text-align: center; font-size: clamp(1.6rem, 2.5vw, 2.2rem); line-height: 1.2; margin-bottom: 0;">
                Schedule Your <span class="text-gradient-blue">1-on-1</span> Demo Below
            </h2>
            
            <h2 class="fw-black mobile-only" style="text-align: center; line-height: 1.1; margin-bottom: 0;">
                <span style="font-size: 9vw; white-space: nowrap; display: block;">Schedule Your <span class="text-gradient-blue">1-</span></span>
                <span style="font-size: 9vw; white-space: nowrap; display: block;"><span class="text-gradient-blue">on-1</span> Demo Below</span>
            </h2>

            <hr class="schedule-divider" />

            <!-- SUBTEXT -->
            <p class="desktop-only" style="font-size: 1.25rem; font-weight: 700; color: #333; line-height: 1.4; margin-top: 15px; margin-bottom: 0;">
                This call is for established only for restoration companies serious about capturing every<br/>
                high-value job.
            </p>
            
            <p class="mobile-only" style="text-align: center; font-size: 3.8vw; font-weight: 700; color: #333; line-height: 1.3; margin-top: 5px; margin-bottom: 0;">
                <span style="display: block; white-space: nowrap;">This call is for established only for restoration</span>
                <span style="display: block; white-space: nowrap;">companies serious about capturing every high-</span>
                <span style="display: block; white-space: nowrap;">value job.</span>
            </p>

            <div class="calendar-wrapper" style="margin-top: 2rem;">
                <iframe src="https://link.restorationai.io/widget/booking/nxDQ6IYn3QIIvrXS6Ib0" style="width: 100%; border:none; overflow: hidden; min-height: 700px;" scrolling="no" id="amzzk8cUTFJTWf00mnGo_1782168050320"></iframe><br><script src="https://link.restorationai.io/js/form_embed.js" type="text/javascript"></script>
                
                <script is:inline>
                    // Intercept the booking message from the GoHighLevel calendar and force the redirect
                    window.addEventListener("message", function(event) {
                        if (!event.data) return;
                        
                        var dataStr = typeof event.data === 'string' ? event.data.toLowerCase() : JSON.stringify(event.data).toLowerCase();
                        
                        // Ignore standard iframe resize messages
                        if (dataStr.includes('resize') || dataStr.includes('height')) return;

                        // If we detect a calendar booking success message, redirect!
                        if (dataStr.includes('submit') || dataStr.includes('success') || dataStr.includes('booking') || dataStr.includes('appointment')) {
                            window.location.href = '/confirmation';
                        }
                    });
                </script>
            </div>
            
        </div>
    </section>
</Layout>
